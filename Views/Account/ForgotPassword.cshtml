@model ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
}

<style>
    .card-massive {
        border: none;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        border-top: 5px solid #0d6efd; /* Bootstrap Primary Color Accent */
    }

    .form-header {
        padding-bottom: 1.5rem;
        margin-bottom: 2rem;
        border-bottom: 1px solid #e9ecef;
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card card-massive bg-white">
                <div class="card-body p-5">

                    <div class="form-header text-center">
                        <h2 class="fw-bold text-dark">Account Recovery</h2>
                        <p class="text-muted mb-0">Enter your username or email to reset your password</p>
                    </div>

                    <form asp-action="ForgotPassword">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

                        <div class="form-floating mb-4">
                            <input asp-for="Name" class="form-control" placeholder="Enter your Name" />
                            <label asp-for="Name" class="text-secondary">Username or Email</label>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2 mb-4">
                            <button type="submit" class="btn btn-primary btn-lg py-3 fw-bold shadow-sm">
                                Reset Password
                            </button>
                        </div>

                        <div class="text-center">
                            <p class="text-muted mb-0">
                                Remembered your password?
                                <a asp-action="Login" class="text-decoration-none fw-bold">Back to Login</a>
                            </p>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>