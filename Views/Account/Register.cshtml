@model UserViewModel

@{
    ViewData["Title"] = "Register";
}

<style>
    /* Professional Card Styling */
    .card-massive {
        border: none;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08); /* Soft, expensive-looking shadow */
        border-top: 5px solid #0d6efd; /* Bootstrap Primary Color Accent */
    }

    .form-header {
        padding-bottom: 1.5rem;
        margin-bottom: 2rem;
        border-bottom: 1px solid #e9ecef;
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card card-massive bg-white">
                <div class="card-body p-5">

                    <div class="form-header text-center">
                        <h2 class="fw-bold text-dark">Create Account</h2>
                        <p class="text-muted mb-0">Please fill in your details to register</p>
                    </div>

                    <form asp-action="Register">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Name" class="form-control" placeholder="Full Name" />
                            <label asp-for="Name" class="text-secondary">Full Name</label>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                                    <label asp-for="Email" class="text-secondary">Email Address</label>
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Mobile" class="form-control" placeholder="Mobile" />
                                    <label asp-for="Mobile" class="text-secondary">Mobile Number</label>
                                    <span asp-validation-for="Mobile" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Password" type="password" class="form-control" placeholder="Password" />
                                    <label asp-for="Password" class="text-secondary">Password</label>
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm Password" />
                                    <label asp-for="ConfirmPassword" class="text-secondary">Confirm Password</label>
                                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mb-4">
                            <button type="submit" class="btn btn-primary btn-lg py-3 fw-bold shadow-sm">
                                Register
                            </button>
                        </div>

                        <div class="text-center">
                            <p class="text-muted">
                                Already have an account?
                                <a asp-action="Login" class="text-decoration-none fw-bold">Log In</a>
                            </p>
                            
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>