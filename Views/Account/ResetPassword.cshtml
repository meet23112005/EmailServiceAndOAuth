@model ResetPasswordViewModel

@{
    ViewData["Title"] = "Reset Password";
    // Get values from the URL to put into the hidden fields
    var userId = Context.Request.Query["UserId"];
    var token = Context.Request.Query["Token"];
}

<style>
    .card-massive {
        border: none;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        border-top: 5px solid #0d6efd;
    }

    .form-header {
        padding-bottom: 1.5rem;
        margin-bottom: 2rem;
        border-bottom: 1px solid #e9ecef;
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card card-massive bg-white">
                <div class="card-body p-5">

                    <div class="form-header text-center">
                        <h2 class="fw-bold text-dark">Set New Password</h2>
                        <p class="text-muted mb-0">Please create a strong password for your account</p>
                    </div>

                    <form asp-action="ResetPassword" method="post" asp-route-UserId="@userId" asp-route-Token = "@token">

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

                        

                        <div class="form-floating mb-3">
                            <input asp-for="Password" type="password" class="form-control" placeholder="New Password" />
                            <label asp-for="Password" class="text-secondary">New Password</label>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm Password" />
                            <label asp-for="ConfirmPassword" class="text-secondary">Confirm Password</label>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2 mb-4">
                            <button type="submit" class="btn btn-primary btn-lg py-3 fw-bold shadow-sm">
                                Change Password
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}